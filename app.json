      "EXPO_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVyZGxsY213enFxYmV2ZmRrbmJoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njk5MDQ0NjcsImV4cCI6MjA4NTQ4MDQ2N30.i4XUP0QSoRtnfyqRB5Ie76GNrpijdNyKnh1HHvYks84",
      "EXPO_PUBLIC_PASSWORD_RESET_REDIRECT_URL": "zenith://auth/reset-password"
